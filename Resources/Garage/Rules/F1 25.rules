;;;-------------------------------------------------------------------------;;;
;;;                            Initialization                               ;;;
;;;-------------------------------------------------------------------------;;;

[?Initialize] => (Prove: addSimulator("F1 25")),
				 (Prove: addCharacteristics("F1 25", *, *, *)),
				 (Prove: addSettings("F1 25", *, *))


