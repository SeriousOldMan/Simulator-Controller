;;;-------------------------------------------------------------------------;;;
;;;                            Initialization                               ;;;
;;;-------------------------------------------------------------------------;;;

[?Initialize] => (Prove: addSettings("Le Mans Ultimate", "Duqueine D09 P3",
									 [Spring.Rate.Front.Heave, Spring.Rate.Rear.Heave,
									  Bumpstop.Range.Front.Heave, Bumpstop.Range.Rear.Heave,
									  Differential.Coast, Differential.Power])),
				 (Prove: removeSettings("Le Mans Ultimate", "Duqueine D09 P3", [Electronics.Map, Aero.Splitter.Front]))